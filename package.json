    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  }
}
